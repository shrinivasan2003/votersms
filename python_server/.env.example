# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST="localhost"
DB_PORT=3306
DB_USER="votersms_app"          # use a dedicated limited DB user in production
DB_PASS="CHANGE_ME"
DB_NAME="votersms"
PORT=8000

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX_STRING"
JWT_EXPIRE_MINUTES=1440          # 24 hours

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Dev default is already set in the app; override here for production.
ALLOWED_ORIGINS="https://app.yourdomain.com"

# ── Postmark webhook security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
# Then set the Postmark webhook URL to: https://<host>/api/email-webhooks?secret=<this value>
WEBHOOK_SECRET="CHANGE_ME_GENERATE_A_RANDOM_STRING"
